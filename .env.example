# ── AI Provider ───────────────────────────────────────────────────────────────
# Required: Get your key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Only needed if you switch to Anthropic models
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── MongoDB (Required for Auth) ────────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rankforge?retryWrites=true&w=majority

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-string

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=RankForge
APP_VERSION=1.0.0
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── AI Models (Groq) ───────────────────────────────────────────────────────────
RESEARCHER_MODEL=llama-3.3-70b-versatile
WRITER_MODEL=llama-3.3-70b-versatile
EDITOR_MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.7
MAX_TOKENS=4000

# ── Performance ────────────────────────────────────────────────────────────────
MAX_WORKERS=4
REQUEST_TIMEOUT=300
MAX_RETRIES=3

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
RATE_LIMIT_PER_HOUR=100

# ── CORS (Frontend URL) ────────────────────────────────────────────────────────
# Set to your frontend domain in production, e.g. https://rankforge.vercel.app
# Leave empty to allow all origins (dev only)
ALLOWED_ORIGINS=http://localhost:5173
